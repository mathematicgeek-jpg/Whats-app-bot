# ============================================
# Meta WhatsApp Cloud API
# ============================================
META_VERIFY_TOKEN=MATH_GEEK_BOT_VERIFY_TOKEN
META_ACCESS_TOKEN=your_meta_system_user_access_token_here
META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
META_APP_SECRET=your_meta_app_secret_here

# ============================================
# Upstash Redis (Serverless Sessions)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# ============================================
# PostgreSQL (Neon Serverless or local)
# ============================================
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ============================================
# Optional
# ============================================
LOG_LEVEL=info
