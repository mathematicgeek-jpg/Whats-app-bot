# Backend Server Port
PORT=3001

# Meta WhatsApp Webhook Configuration
# This is the verify token you choose and input in the Meta Developer Console
META_VERIFY_TOKEN=MATH_GEEK_BOT_VERIFY_TOKEN

# Meta WhatsApp Cloud API credentials
# Add your permanent Graph API Access Token and Phone Number ID here to enable real message dispatching.
META_ACCESS_TOKEN=your_meta_system_user_access_token_here
META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
